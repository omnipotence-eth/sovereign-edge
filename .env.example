# =============================================================================
# Sovereign Edge — environment variable reference
# Copy to .env and fill in your values.  Never commit .env to version control.
# =============================================================================

# ── LLM providers (at least one required) ────────────────────────────────────
# Priority order: Groq → Gemini → Cerebras → Mistral.
# The first provider with a key set is tried first; others are fallbacks.
GROQ_API_KEY=
GEMINI_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=

# ── Telegram ──────────────────────────────────────────────────────────────────
# Required: obtain from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=
# Required: your personal Telegram user ID (integer).
# Find it by messaging @userinfobot on Telegram.
TELEGRAM_ALLOWED_USER_ID=

# ── Intelligence squad ────────────────────────────────────────────────────────
# Optional: enables earnings call transcript summaries (Layer 2).
# Free tier: 250 requests/day.  Sign up at financialmodelingprep.com.
FMP_API_KEY=
# Symbols to monitor for price alerts and technical signals.
# WATCHLIST=NVDA,MSFT,GOOGL,META

# ── Voice service ─────────────────────────────────────────────────────────────
# faster-whisper model size: tiny.en | base.en | small.en | medium.en
# STT_MODEL=base.en

# ── Memory / vector store ─────────────────────────────────────────────────────
# MEM0_USER_ID=john
# LANCEDB_PATH=data/lancedb
# SKILL_DB_PATH=data/skills.db

# ── Observability ─────────────────────────────────────────────────────────────
# Set LOG_JSON=true in production for structured JSON logs.
# LOG_JSON=false
# LOG_LEVEL=INFO
# OTEL endpoint (OTLP gRPC).  Leave blank to disable OTEL export.
# OTEL_ENDPOINT=http://localhost:4317

# ── Scheduling ────────────────────────────────────────────────────────────────
# Hour (0-23) for each scheduled task.
# MORNING_BRIEF_HOUR=6
# JOB_SCAN_HOUR=9
# MARKET_SUMMARY_HOUR=18
